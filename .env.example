# OSINT-SCRAPING Environment Variables

# === Google APIs ===
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# === Apify (Scraping Platform) ===
APIFY_TOKEN=your_apify_token
APIFY_GOOGLE_SCRAPER_ACTOR_ID=google-search-scraper

# === Outscraper (Google Maps Scraping) ===
OUTSCRAPER_KEY=your_outscraper_api_key

# === Browser Configuration ===
HEADLESS=true
BROWSER_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000

# === Data Extraction ===
EXPORT_FORMAT=json
EXPORT_PATH=./data/exports
CAC HE_ENABLED=true
CACHE_TTL=3600

# === Database (Optional) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=osint_db
DB_USER=postgres
DB_PASS=postgres
DB_ENABLED=false

# === Proxy Configuration (Optional) ===
PROXY_ENABLED=false
PROXY_URL=http://proxy.example.com:8080
PROXY_USERNAME=
PROXY_PASSWORD=

# === Logging ===
LOG_LEVEL=info
LOG_FILE=./logs/osint.log

# === Rate Limiting ===
REQUEST_DELAY_MS=1000
BETWEEN_PAGE_DELAY_MS=2000

# === Development ===
NODE_ENV=development
DEBUG=false

# === BCRA Configuration ===
BCRA_BASE_URL=https://www.bcra.gob.ar
BCRA_DEUDORES_PATH=/situacion-crediticia/

# === ANSES Configuration ===
ANSES_BASE_URL=https://servicioswww.anses.gob.ar
ANSES_CUIL_PATH=/C2-ConstaCUIL

# === Boletin Oficial GBA ===
BOLETIN_BASE_URL=https://boletinoficial.gba.gob.ar
BOLETIN_EXTRACT_PAGES=5
